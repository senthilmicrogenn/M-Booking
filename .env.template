# RoomNest Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://roomnest_user:your_secure_password@localhost:5432/roomnest_db

# ==============================================
# GOOGLE CLOUD STORAGE CONFIGURATION
# ==============================================
# Google Cloud Storage bucket name for photo storage
GCS_BUCKET_NAME=roomnest-photos

# Path to Google Cloud service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/var/www/roomnest/credentials/google-cloud-key.json

# ==============================================
# SESSION CONFIGURATION
# ==============================================
# Strong random session secret (minimum 32 characters)
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_very_long_random_session_secret_here_minimum_32_characters

# ==============================================
# EMAIL CONFIGURATION (Optional)
# ==============================================
# Gmail SMTP configuration for booking confirmation emails
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-specific-password

# Alternative email providers (if not using Gmail):
# SENDGRID_API_KEY=your_sendgrid_api_key
# BREVO_API_KEY=your_brevo_api_key

# ==============================================
# APPLICATION CONFIGURATION
# ==============================================
# Node environment (development or production)
NODE_ENV=production

# Port for the application (default: 5000)
PORT=5000

# ==============================================
# SECURITY NOTES
# ==============================================
# 1. Never commit this .env file to version control
# 2. Use strong, unique passwords
# 3. Rotate SESSION_SECRET periodically
# 4. Keep Google Cloud credentials secure
# 5. Use app-specific passwords for Gmail (not your main password)
